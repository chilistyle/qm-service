{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "views/**/*", "watch": true },
      { "include": "public/**/*", "watch": true }
    ],
    "watchAssets": true
  }
}
