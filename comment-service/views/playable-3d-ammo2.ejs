<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>3D Bowling Playable</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background: #0e0e0e;
            font-family: 'Arial Black', sans-serif;
        }

        #ui {
            position: absolute;
            top: 20px;
            width: 100%;
            text-align: center;
            color: #fff;
            pointer-events: none;
            text-shadow: 0 0 10px #ff00ff;
        }

        #cta-btn {
            display: none;
            position: absolute;
            bottom: 50px;
            left: 50%;
            transform: translateX(-50%);
            padding: 20px 50px;
            background: linear-gradient(45deg, #ff00ff, #00ffff);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 24px;
            cursor: pointer;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <div id="ui">
        <h1>STRIKE CHALLENGE</h1>
        <p>Swipe up to throw the ball!</p>
    </div>
    <button id="cta-btn" onclick="window.handleCTA()">PLAY AGAIN</button>

    <script src="https://cdn.babylonjs.com/ammo.js"></script>

    <script type="module">
        import * as THREE from 'https://cdnjs.cloudflare.com/ajax/libs/three.js/0.180.0/three.module.js';

        let physicsWorld, scene, camera, renderer, clock, tmpTrans;
        let rigidBodies = [], pins = [];
        let ballBody, ballMesh;
        let isLaunched = false;

        // Ammo initialization
        window.Ammo().then((AmmoLib) => {
            tmpTrans = new AmmoLib.btTransform();
            init(AmmoLib);
        });

        let startY = 0;
        let startTime = 0;
        let startX = 0;

        function init(Ammo) {
            setupPhysics(Ammo);
            setupVisuals();
            createAlley(Ammo);
            createPins(Ammo);
            createBall(Ammo);

            animate(Ammo);

            // Throw handling (swipe or long click)
            window.addEventListener('mousedown', (e) => {
                if (isLaunched) return;
                startX = e.clientX;
                startY = e.clientY;
                startTime = Date.now();
            });

            // Capture swipe end and launch
            window.addEventListener('mouseup', (e) => {
                if (isLaunched || startTime === 0) return;

                const endX = e.clientX;
                const endY = e.clientY;
                const endTime = Date.now();

                const duration = endTime - startTime;
                const diffY = startY - endY; // Скільки проїхали вгору
                const diffX = endX - startX; // Відхилення вбік

                // If the swipe was fast and long enough (upwards)
                if (diffY > 50 && duration < 500) {
                    isLaunched = true;

                    // Unfreeze physics
                    ballBody.setLinearFactor(new Ammo.btVector3(1, 1, 1));
                    ballBody.setAngularFactor(new Ammo.btVector3(1, 1, 1));
                    ballBody.setActivationState(1);

                    // Force calculation: the faster the swipe, the stronger the hit
                    const power = Math.min(diffY / duration * 10, 60);
                    const sideSteer = (diffX / window.innerWidth) * 20;

                    ballBody.setLinearVelocity(new Ammo.btVector3(sideSteer, 0, -power));
                    ballBody.setAngularVelocity(new Ammo.btVector3(-power / 2, 0, 0)); // Spin forward

                    setTimeout(() => {
                        document.getElementById('cta-btn').style.display = 'block';
                    }, 4000);
                }

                startTime = 0; // Reset timer
            });

            window.handleCTA = () => window.location.reload();
        }

        function setupPhysics(Ammo) {
            const colConfig = new Ammo.btDefaultCollisionConfiguration();
            const disp = new Ammo.btCollisionDispatcher(colConfig);
            const cache = new Ammo.btDbvtBroadphase();
            const solv = new Ammo.btSequentialImpulseConstraintSolver();
            physicsWorld = new Ammo.btDiscreteDynamicsWorld(disp, cache, solv, colConfig);
            physicsWorld.setGravity(new Ammo.btVector3(0, -9.81, 0));
        }

        function setupVisuals() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 1, 1000);
            camera.position.set(0, 5, 25);
            camera.lookAt(0, 0, -10);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            document.body.appendChild(renderer.domElement);

            scene.add(new THREE.AmbientLight(0xffffff, 0.4));
            const spot = new THREE.SpotLight(0xffffff, 1.5);
            spot.position.set(0, 20, 10);
            spot.castShadow = true;
            scene.add(spot);

            clock = new THREE.Clock();
        }

        function createAlley(Ammo) {
            // Lane
            const size = { x: 10, y: 1, z: 65 };
            const mesh = new THREE.Mesh(
                new THREE.BoxGeometry(size.x, size.y, size.z),
                new THREE.MeshPhongMaterial({ color: 0x1a1a1a, shininess: 100 })
            );
            mesh.position.z = -15;
            mesh.receiveShadow = true;
            scene.add(mesh);

            const transform = new Ammo.btTransform();
            transform.setIdentity();
            transform.setOrigin(new Ammo.btVector3(0, -0.5, -15));
            const colShape = new Ammo.btBoxShape(new Ammo.btVector3(size.x / 2, size.y / 1, size.z / 2));
            const body = new Ammo.btRigidBody(new Ammo.btRigidBodyConstructionInfo(0, new Ammo.btDefaultMotionState(transform), colShape, new Ammo.btVector3(0, 0, 0)));
            body.setFriction(0.1); // Slippery lane
            physicsWorld.addRigidBody(body);
        }

        function createPins(Ammo) {
            const pinRows = 4;
            const spacing = 1.2;
            let pinIdx = 0;

            Array.from({ length: pinRows }).forEach((_, row) => {
                Array.from({ length: row + 1 }).forEach((_, col) => {
                    const x = (col - row / 2) * spacing;
                    const z = -30 - row * spacing;
                    createPin(Ammo, { x, y: 1, z });
                });
            });
        }

        function createPin(Ammo, pos) {
            const w = 0.5, h = 1.8;
            const mesh = new THREE.Mesh(
                new THREE.CylinderGeometry(w * 0.6, w, h, 16),
                new THREE.MeshPhongMaterial({ color: 0xffffff })
            );
            mesh.castShadow = true;
            scene.add(mesh);

            const transform = new Ammo.btTransform();
            transform.setIdentity();
            transform.setOrigin(new Ammo.btVector3(pos.x, pos.y, pos.z));
            const colShape = new Ammo.btCylinderShape(new Ammo.btVector3(w, h / 2, w));
            const localInertia = new Ammo.btVector3(0, 0, 0);
            colShape.calculateLocalInertia(1, localInertia);

            const body = new Ammo.btRigidBody(new Ammo.btRigidBodyConstructionInfo(1, new Ammo.btDefaultMotionState(transform), colShape, localInertia));
            physicsWorld.addRigidBody(body);
            rigidBodies.push({ mesh, body });
        }

        function createBall(Ammo) {
            const radius = 0.8;
            ballMesh = new THREE.Mesh(
                new THREE.SphereGeometry(radius, 32, 32),
                new THREE.MeshPhongMaterial({ color: 0xff00ff, shininess: 100 })
            );
            ballMesh.castShadow = true;
            scene.add(ballMesh);

            const transform = new Ammo.btTransform();
            transform.setIdentity();
            transform.setOrigin(new Ammo.btVector3(0, radius, 15));
            const colShape = new Ammo.btSphereShape(radius);
            const localInertia = new Ammo.btVector3(0, 0, 0);
            colShape.calculateLocalInertia(5, localInertia);

            ballBody = new Ammo.btRigidBody(new Ammo.btRigidBodyConstructionInfo(5, new Ammo.btDefaultMotionState(transform), colShape, localInertia));
            physicsWorld.addRigidBody(ballBody);
            rigidBodies.push({ mesh: ballMesh, body: ballBody });
            ballBody.setAngularFactor(new Ammo.btVector3(0, 0, 0)); // Disable rotation before start
            ballBody.setLinearFactor(new Ammo.btVector3(0, 0, 0));  // Disable movement before start
        }

        function animate(Ammo) {
            requestAnimationFrame(() => animate(Ammo));
            const deltaTime = clock.getDelta();
            physicsWorld.stepSimulation(deltaTime, 10);

            for (const obj of rigidBodies) {
                const ms = obj.body.getMotionState();
                if (ms) {
                    ms.getWorldTransform(tmpTrans);
                    const p = tmpTrans.getOrigin();
                    const q = tmpTrans.getRotation();
                    obj.mesh.position.set(p.x(), p.y(), p.z());
                    obj.mesh.quaternion.set(q.x(), q.y(), q.z(), q.w());
                }
            }
            renderer.render(scene, camera);
        }
    </script>
</body>

</html>