<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>3D Physics Playable</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <style>
        body { margin: 0; overflow: hidden; background: #111; font-family: sans-serif; }
        #ui { position: absolute; top: 20px; width: 100%; text-align: center; color: #00ffcc; pointer-events: none; }
        #cta-btn { 
            display: none; position: absolute; bottom: 50px; left: 50%; transform: translateX(-50%); 
            padding: 18px 45px; background: #00ffcc; color: #111; border: none; border-radius: 50px; 
            font-size: 22px; font-weight: bold; cursor: pointer; box-shadow: 0 0 20px rgba(0,255,204,0.4);
        }
    </style>
</head>
<body>
    <div id="ui">
        <h1>PHYSICS PLAYGROUND</h1>
        <p>Click to knock down the tower</p>
    </div>
    <button id="cta-btn" onclick="window.handleCTA()">DOWNLOAD</button>

    <script src="https://cdn.babylonjs.com/ammo.js"></script>

    <script type="module">
        import * as THREE from 'https://cdnjs.cloudflare.com/ajax/libs/three.js/0.180.0/three.module.js';

        let physicsWorld, scene, camera, renderer, clock;
        let rigidBodies = [];
        let tmpTrans;
        let shotsFired = 0;

        // Wait for Ammo initialization
        window.Ammo().then((AmmoLib) => {
            tmpTrans = new AmmoLib.btTransform();
            init(AmmoLib);
        });

        function init(Ammo) {
            setupPhysics(Ammo);
            setupVisuals();
            createGround(Ammo);
            createTower(Ammo);
            
            animate(Ammo);

            window.addEventListener('mousedown', (e) => shootBox(e, Ammo));
            window.handleCTA = () => window.open("<%= storeUrl %>", "_blank");
        }

        function setupPhysics(Ammo) {
            const colConfig = new Ammo.btDefaultCollisionConfiguration();
            const disp = new Ammo.btCollisionDispatcher(colConfig);
            const cache = new Ammo.btDbvtBroadphase();
            const solv = new Ammo.btSequentialImpulseConstraintSolver();
            
            physicsWorld = new Ammo.btDiscreteDynamicsWorld(disp, cache, solv, colConfig);
            physicsWorld.setGravity(new Ammo.btVector3(0, -9.81, 0));
        }

        function setupVisuals() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 1, 1000);
            camera.position.set(0, 10, 20);
            camera.lookAt(0, 3, 0);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            document.body.appendChild(renderer.domElement);

            scene.add(new THREE.AmbientLight(0xffffff, 0.5));
            const light = new THREE.DirectionalLight(0xffffff, 1.2);
            light.position.set(10, 25, 10);
            light.castShadow = true;
            scene.add(light);
            
            clock = new THREE.Clock();
        }

        function createGround(Ammo) {
            const size = { x: 50, y: 1, z: 50 };
            const mesh = new THREE.Mesh(
                new THREE.BoxGeometry(size.x, size.y, size.z),
                new THREE.MeshPhongMaterial({ color: 0x222222 })
            );
            mesh.position.y = -0.5;
            mesh.receiveShadow = true;
            scene.add(mesh);

            const transform = new Ammo.btTransform();
            transform.setIdentity();
            transform.setOrigin(new Ammo.btVector3(0, -0.5, 0));
            const colShape = new Ammo.btBoxShape(new Ammo.btVector3(size.x/2, size.y/2, size.z/2));
            const rbInfo = new Ammo.btRigidBodyConstructionInfo(0, new Ammo.btDefaultMotionState(transform), colShape, new Ammo.btVector3(0,0,0));
            const body = new Ammo.btRigidBody(rbInfo);
            physicsWorld.addRigidBody(body);
        }

        function createTower(Ammo) {
            Array.from({ length: 6 }).forEach((_, i) => {
                [-1.1, 0, 1.1].forEach((xOffset) => {
                    createBox(Ammo, { x: xOffset, y: i * 1.1 + 0.6, z: 0 }, 2, 0x00ffcc);
                });
            });
        }

        function createBox(Ammo, pos, mass, color) {
            const size = 1;
            const mesh = new THREE.Mesh(new THREE.BoxGeometry(size, size, size), new THREE.MeshPhongMaterial({ color }));
            mesh.castShadow = true;
            scene.add(mesh);

            const transform = new Ammo.btTransform();
            transform.setIdentity();
            transform.setOrigin(new Ammo.btVector3(pos.x, pos.y, pos.z));
            const colShape = new Ammo.btBoxShape(new Ammo.btVector3(size/2, size/2, size/2));
            const localInertia = new Ammo.btVector3(0, 0, 0);
            colShape.calculateLocalInertia(mass, localInertia);
            const rbInfo = new Ammo.btRigidBodyConstructionInfo(mass, new Ammo.btDefaultMotionState(transform), colShape, localInertia);
            const body = new Ammo.btRigidBody(rbInfo);
            
            physicsWorld.addRigidBody(body);
            rigidBodies.push({ mesh, body });
        }

        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();

        function shootBox(event, Ammo) {
            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;
            raycaster.setFromCamera(mouse, camera);

            const dir = raycaster.ray.direction;
            const size = 0.8;
            const mass = 15;
            
            const mesh = new THREE.Mesh(new THREE.BoxGeometry(size, size, size), new THREE.MeshPhongMaterial({ color: 0xff4444 }));
            mesh.castShadow = true;
            scene.add(mesh);

            const transform = new Ammo.btTransform();
            transform.setIdentity();
            transform.setOrigin(new Ammo.btVector3(camera.position.x, camera.position.y, camera.position.z));
            const colShape = new Ammo.btBoxShape(new Ammo.btVector3(size/2, size/2, size/2));
            const localInertia = new Ammo.btVector3(0, 0, 0);
            colShape.calculateLocalInertia(mass, localInertia);
            const rbInfo = new Ammo.btRigidBodyConstructionInfo(mass, new Ammo.btDefaultMotionState(transform), colShape, localInertia);
            const body = new Ammo.btRigidBody(rbInfo);

            const force = 65;
            body.setLinearVelocity(new Ammo.btVector3(dir.x * force, dir.y * force, dir.z * force));
            physicsWorld.addRigidBody(body);
            rigidBodies.push({ mesh, body });

            shotsFired++;
            if(shotsFired >= 5) {
                document.getElementById('cta-btn').style.display = 'block';
            }
        }

        function animate(Ammo) {
            requestAnimationFrame(() => animate(Ammo));
            const deltaTime = clock.getDelta();
            
            physicsWorld.stepSimulation(deltaTime, 10);

            // Synchronization via for...of (without comparison symbols)
            for (const obj of rigidBodies) {
                const ms = obj.body.getMotionState();
                if (ms) {
                    ms.getWorldTransform(tmpTrans);
                    const p = tmpTrans.getOrigin();
                    const q = tmpTrans.getRotation();
                    obj.mesh.position.set(p.x(), p.y(), p.z());
                    obj.mesh.quaternion.set(q.x(), q.y(), q.z(), q.w());
                }
            }
            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
