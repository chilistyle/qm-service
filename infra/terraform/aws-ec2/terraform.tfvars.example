aws_region        = "eu-central-1"
instance_name     = "qm-service-prod"
instance_type     = "t3.large"
ssh_allowed_cidr  = "YOUR_PUBLIC_IP/32"
key_name          = "your-existing-aws-keypair"
root_volume_size  = 60

app_repo_url      = "https://github.com/chilistyle/qm-service.git"
app_repo_branch   = "main"

enable_https      = true
extra_ingress_ports = [8080, 8761]
